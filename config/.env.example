# =============================================================
# RendaExtraCupuns — Configuração do Ambiente
# Copie este arquivo como .env e preencha os valores
# =============================================================

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHANNEL_ID=@seud_canal

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_GROUP_IDS=120363000000000000@g.us,120363000000000001@g.us
WHATSAPP_NEWSLETTER_ID=
WHATSAPP_SESSION_PATH=./whatsapp-session

# ── Amazon Afiliados ──────────────────────────────────────────
AMAZON_AFFILIATE_TAG=seudominio-20
AMAZON_MARKETPLACE=www.amazon.com.br

# ── AliExpress Afiliados ──────────────────────────────────────
# Cadastre-se em https://portals.aliexpress.com e insira seu ID aqui
ALIEXPRESS_AFFILIATE_ID=seu_ali_id

# ── Shopee Afiliados ──────────────────────────────────────────
SHOPEE_AFFILIATE_ID=seu_shopee_id

# ── Mercado Livre Afiliados ───────────────────────────────────
MERCADOLIVRE_AFFILIATE_ID=seu_ml_id

# ── Mercado Livre OAuth (API autenticada) ─────────────────────
# Crie um app em https://developers.mercadolibre.com.br/
# Depois execute: node scripts/setup-ml-oauth.js
ML_CLIENT_ID=seu_app_id
ML_SECRET_KEY=sua_secret_key
ML_ACCESS_TOKEN=token_gerado_pelo_oauth
ML_REFRESH_TOKEN=refresh_token_gerado_pelo_oauth
